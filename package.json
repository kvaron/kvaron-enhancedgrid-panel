{
  "name": "enhancedgrid",
  "version": "0.3.0",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "e2e:grid": "playwright test grid-layout grid-interaction",
    "e2e:grid-watch": "playwright test grid-layout grid-interaction --ui",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Kvaron",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.9.1",
    "@grafana/tsconfig": "2.2.0",
    "@playwright/test": "^1.61.0",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.8",
    "semver": "^7.8.5",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-node": "^10.9.0",
    "typescript": "5.9.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "ws": "^8.21.0",
    "@babel/core": "7.29.6",
    "@opentelemetry/core": "2.8.0",
    "dompurify": "3.4.11",
    "lodash": "4.18.0",
    "postcss": "8.5.10",
    "protocol-buffers-schema": "3.6.1",
