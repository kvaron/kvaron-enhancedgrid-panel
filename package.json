    "brace-expansion@5": "5.0.6",
    "picomatch@2": "2.3.2",
    "picomatch@4": "4.0.4",
    "yaml@1": "1.10.3",
    "yaml@2": "2.8.3",
    "js-yaml@4": "4.2.0"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "13.0.2",
    "@grafana/i18n": "13.0.2",
    "@grafana/runtime": "13.0.2",
    "@grafana/schema": "13.0.2",
    "@grafana/ui": "13.0.2",
    "@tanstack/react-virtual": "^3.14.3",
    "emojibase": "^17.0.0",
    "emojibase-data": "^17.0.0",
